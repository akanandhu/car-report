{
  "name": "frontend-dealers",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:all": "dotenv -e .env.local -- next dev -H 0.0.0.0 -p 3000",
    "build": "next build",
    "build:android": "dotenv -e .env.local -- next build",
    "build:ios": "dotenv -e .env.local -- next build",
    "start": "npx serve@latest out",
    "lint": "eslint",
    "mobile:sync": "npm run build && cap sync",
    "android": "npm run build:android && npx cap sync android && npx cap run android",
    "ios": "npm run build:ios && npx cap sync ios && npx cap run ios",
    "android:dev": "dotenv -e .env.local -- sh -c 'CAP_TARGET=android-dev npx cap sync android && CAP_TARGET=android-dev npx cap run android'",
    "ios:dev": "dotenv -e .env.local -- sh -c 'CAP_TARGET=ios-dev npx cap sync ios && CAP_TARGET=ios-dev npx cap run ios'"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@hookform/resolvers": "^5.2.2",
    "framer-motion": "^12.33.0",
    "lucide-react": "^1.16.0",
    "next": "16.1.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.1",
    "react-hot-toast": "^2.6.0",
    "recharts": "^3.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
